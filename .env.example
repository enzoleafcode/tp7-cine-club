# Copier ce fichier en .env puis adapter les valeurs :
#   cp .env.example .env
# Le .env reel n'est PAS versionne (voir .gitignore).

# --- Base de donnees PostgreSQL (doit correspondre a docker-compose.yml) ---
DB_NAME=cineclubdb
DB_USERNAME=cineclubuser
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5440

# --- JWT ---
# JWT_SECRET : minimum 256 bits (>= 32 caracteres). En prod, generer une vraie
# cle aleatoire, ex : openssl rand -base64 48
JWT_SECRET=remplacer-par-une-cle-aleatoire-de-256-bits-minimum
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000
